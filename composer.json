{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*", 
        "ext-curl": "*",
        "ext-iconv": "*",
        "ext-imagick": "*",
        "amzn/amazon-pay-api-sdk-php": "^2.6",
        "aws/aws-sdk-php-symfony": "^2.6",
        "beberlei/doctrineextensions": "^1.4",
        "braintree/braintree_php": "^6.12",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.2",
        "doctrine/orm": "^3.3",
        "dompdf/dompdf": "^3.1",
        "easypost/easypost-php": "^7.4",
        "eckinox/tinymce-bundle": "*",
        "google/apiclient": "^2.18",
        "googleads/google-ads-php": "^28.0",
        "iio/libmergepdf": "^4.0",
        "knplabs/knp-paginator-bundle": "^6.2",
        "league/flysystem-aws-s3-v3": "^3.15",
        "league/flysystem-bundle": "^3.1",
        "microsoft/bingads": "*",
        "mobiledetect/mobiledetectlib": "^4.8",
        "phpdocumentor/reflection-docblock": "^5.3",
        "phpoffice/phpspreadsheet": "^1.29",
        "phpstan/phpdoc-parser": "^1.22",
        "predis/predis": "^3.0",
        "scienta/doctrine-json-functions": "^5.4",
        "stripe/stripe-php": "^16.2",
        "symfony/asset": "*",
        "symfony/cache": "7.2.*",
        "symfony/console": "*",
        "symfony/doctrine-messenger": "*",
        "symfony/dotenv": "*",
        "symfony/expression-language": "*",
        "symfony/flex": "^2.4.7",
        "symfony/form": "*",
        "symfony/framework-bundle": "*",
        "symfony/http-client": "*",
        "symfony/intl": "*",
        "symfony/lock": "*",
        "symfony/mailer": "*",
        "symfony/mercure-bundle": "^0.3.9",
        "symfony/messenger": "*",
        "symfony/mime": "*",
        "symfony/monolog-bundle": "^3.0",
        "symfony/notifier": "*",
        "symfony/process": "*",
        "symfony/property-access": "*",
        "symfony/property-info": "*",
        "symfony/rate-limiter": "7.2.*",
        "symfony/runtime": "*",
        "symfony/security-bundle": "*",
        "symfony/sendgrid-mailer": "*",
        "symfony/serializer": "*",
        "symfony/string": "*",
        "symfony/translation": "*",
        "symfony/twig-bundle": "*",
        "symfony/ux-autocomplete": "2.23.0",
        "symfony/ux-live-component": "2.23.0",
        "symfony/ux-react": "^2.23.0",
        "symfony/validator": "*",
        "symfony/web-link": "*",
        "symfony/webpack-encore-bundle": "^2.2.0",
        "symfony/yaml": "*",
        "twig/extra-bundle": "^3.20.0",
        "twig/twig": "^3.20.0",
        "twilio/sdk": "^8.6",
        "vich/uploader-bundle": "^2.1"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear --no-warmup": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "pre-autoload-dump": "Google\\Task\\Composer::cleanup"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.2.*"
        },
        "google/apiclient-services": [
            "Drive"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "symfony/browser-kit": "*",
        "symfony/css-selector": "*",
        "symfony/debug-bundle": "*",
        "symfony/maker-bundle": "^1.0",
        "symfony/phpunit-bridge": "*",
        "symfony/stopwatch": "*",
        "symfony/web-profiler-bundle": "*"
    }
}
